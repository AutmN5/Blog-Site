<%- include('./partials/header'); -%>

<div class="row mb-5">
  <div class="col-12">
    <div class="ascii-logo">
      // SYSTEM INITIALIZED
      // CONNECTED TO AVIRUP'S MAINFRAME
      // HTTP REQUEST DETECTED...
    </div>
    <h1 class="terminal-header">> BLOG_POSTS_DIRECTORY</h1>
    <p class="text-secondary">Insights, tutorials, and stories from a full-stack developer.</p>
  </div>
</div>

<div class="row g-4">
  <% if (posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 p-3">
          <div class="card-body d-flex flex-column p-0">
            <h5 class="card-title terminal-header" style="font-size: 1.1rem;"><%= post.title %></h5>
            <div class="text-secondary small mb-3" style="border-bottom: 1px dashed #333; padding-bottom: 10px;">
              AUTHOR: <%= post.author.username %><br>
              TIMESTAMP: <%= new Date(post.createdAt).toISOString() %>
            </div>
            <p class="card-text text-light" style="opacity: 0.7; font-size: 0.9rem;">
              <%= post.content.substring(0, 100) %>...
            </p>
            <a href="/posts/<%= post.slug %>" class="btn btn-outline-light mt-auto align-self-start">> READ_MORE</a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12 py-5" style="border: 1px dashed #333; padding: 2rem;">
      <h3 class="text-secondary">NO POSTS FOUND IN DATABASE.</h3>
      <% if (user) { %>
        <a href="/create" class="btn btn-primary mt-3">> EXECUTE_CREATE_POST</a>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('./partials/footer'); -%>

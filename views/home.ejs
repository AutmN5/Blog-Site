<%- include('./partials/header'); -%>

<div class="row mb-5">
  <div class="col-12">
    <div class="ascii-logo">
      // SYSTEM INITIALIZED
      // CONNECTED TO AUTMN'S MAINFRAME
      // HTTP REQUEST DETECTED...
    </div>
    <h1 class="terminal-header">> BLOG_POSTS_DIRECTORY</h1>
    <p class="text-secondary">Insights, tutorials, and stories from a full-stack developer.</p>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-6">
    <form class="d-flex" onsubmit="event.preventDefault();">
      <input type="text" class="form-control me-2" name="search" placeholder="> SEARCH_POSTS..." aria-label="Search posts">
      <button type="button" class="btn btn-outline-light text-nowrap flex-shrink-0" aria-label="Execute search">[ EXEC ]</button>
    </form>
  </div>
</div>

<div class="row g-4">
  <% if (posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="col-md-6 col-lg-4 post-card-container">
        <div class="card h-100 p-3">
          <div class="card-body d-flex flex-column p-0">
            <h5 class="card-title terminal-header" style="font-size: 1.1rem;"><%= post.title %></h5>
            <div class="text-secondary small mb-3" style="border-bottom: 1px dashed #333; padding-bottom: 10px;">
              AUTHOR: <%= post.author.username %><br>
              TIMESTAMP: <%= new Date(post.createdAt).toISOString() %><br>
              <% const words = post.content.split(' ').length; const readTime = Math.ceil(words / 200) || 1; %>
              EST_READ_TIME: <%= readTime %> MIN<br>
              <% if (post.isPrivate) { %>
                <span class="badge bg-danger mt-2 rounded-0">[ PRIVATE_RECORD ]</span>
              <% } %>
            </div>
            <% if (post.tags && post.tags.length > 0) { %>
              <div class="mb-3">
                <% post.tags.forEach(tag => { %>
                  <span class="badge" style="border: 1px solid #4b5563; color: #9ca3af; font-weight: normal; border-radius: 0;">#<%= tag %></span>
                <% }) %>
              </div>
            <% } %>
            <p class="card-text text-light" style="opacity: 0.7; font-size: 0.9rem;">
              <%= post.content.substring(0, 100) %>...
            </p>
            <a href="/posts/<%= post.slug %>" class="btn btn-outline-light mt-auto align-self-start">> READ_MORE</a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12 py-5" style="border: 1px dashed #333; padding: 2rem;">
      <h3 class="text-secondary">NO POSTS FOUND IN DATABASE.</h3>
      <% if (user) { %>
        <a href="/create" class="btn btn-primary mt-3">> EXECUTE_CREATE_POST</a>
      <% } %>
    </div>
  <% } %>
</div>

<script>
  const searchInput = document.querySelector('input[name="search"]');
  const postCards = document.querySelectorAll('.post-card-container');
  
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      postCards.forEach(card => {
        const text = card.innerText.toLowerCase();
        if (text.includes(term)) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }
</script>

<%- include('./partials/footer'); -%>

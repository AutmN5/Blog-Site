<%- include('./partials/header'); -%>

<div class="row mb-5">
  <div class="col-12 text-center">
    <h1 class="display-4 fw-bold">Avirup Mondal's Blog</h1>
    <p class="lead text-muted">Insights, tutorials, and stories from a full-stack developer.</p>
  </div>
</div>

<div class="row g-4">
  <% if (posts.length > 0) { %>
    <% posts.forEach(post => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm border border-secondary rounded-4 bg-dark text-light">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold"><%= post.title %></h5>
            <div class="text-muted small mb-3">
              By <%= post.author.username %> &bull; <%= new Date(post.createdAt).toLocaleDateString() %>
            </div>
            <p class="card-text text-light" style="opacity: 0.8;">
              <%= post.content.substring(0, 100) %>...
            </p>
            <a href="/posts/<%= post.slug %>" class="btn btn-primary mt-auto align-self-start rounded-pill px-4">Read More</a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-12 text-center py-5">
      <h3 class="text-muted">No posts available yet.</h3>
      <% if (user) { %>
        <a href="/create" class="btn btn-primary mt-3 rounded-pill px-4">Create your first post</a>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('./partials/footer'); -%>

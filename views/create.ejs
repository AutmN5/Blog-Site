<%- include('./partials/header'); -%>

<div class="row justify-content-center mt-4">
  <div class="col-md-8">
    <div class="ascii-logo">
      // INITIALIZING NEW_POST_WIZARD.EXE
      // WAITING FOR USER INPUT...
    </div>
    <div class="card p-4 p-md-5">
      <div class="card-body">
        <h2 class="terminal-header mb-4">> CREATE_NEW_POST</h2>
        <form action="/create" method="POST">
          <div class="mb-4">
            <label for="title" class="form-label text-secondary">POST_TITLE:</label>
            <input type="text" class="form-control" id="title" name="title" required placeholder="> type title here...">
          </div>
          <div class="mb-4">
            <label for="content" class="form-label text-secondary">POST_CONTENT:</label>
            <textarea class="form-control" id="content" name="content" rows="12" required placeholder="> start typing your content..."></textarea>
          </div>
          <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary px-5 py-2">[ PUBLISH_RECORD ]</button>
            <a href="/" class="btn btn-outline-light px-4 py-2">[ CANCEL ]</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer'); -%>

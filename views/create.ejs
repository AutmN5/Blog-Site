<%- include('./partials/header'); -%>

<div class="row justify-content-center mt-4">
  <div class="col-md-8">
    <div class="ascii-logo">
      // INITIALIZING NEW_POST_WIZARD.EXE
      // WAITING FOR USER INPUT...
    </div>
    <div class="card p-4 p-md-5">
      <div class="card-body">
        <h2 class="terminal-header mb-4">> CREATE_NEW_POST</h2>
        <form action="/create" method="POST">
          <div class="mb-4">
            <label for="title" class="form-label text-secondary">POST_TITLE:</label>
            <input type="text" class="form-control" id="title" name="title" required placeholder="> type title here...">
          </div>
          <div class="mb-4">
            <label for="content" class="form-label text-secondary">POST_CONTENT:</label>
            <textarea class="form-control" id="content" name="content" rows="12" required spellcheck="true" placeholder="> start typing your content..."></textarea>
          </div>
          
          <div class="mb-4">
            <label for="tags" class="form-label text-secondary">TAGS (COMMA SEPARATED):</label>
            <input type="text" class="form-control" id="tags" name="tags" placeholder="> e.g. code, life, matrix">
          </div>
          
          <div class="mb-4 d-flex flex-wrap align-items-center gap-4">
            <div class="form-check form-switch d-flex align-items-center ps-0 me-2">
              <input class="form-check-input ms-0 me-2" type="checkbox" id="isPrivate" name="isPrivate" style="background-color: transparent; border-color: #333; margin-top: 0;">
              <label class="form-check-label text-secondary" style="font-size: 0.9rem;" for="isPrivate">[ ENABLE_PRIVATE_MODE ]</label>
            </div>

            <div class="form-check form-switch d-flex align-items-center ps-0 me-2">
              <input class="form-check-input ms-0 me-2" type="checkbox" id="isGated" name="isGated" style="background-color: transparent; border-color: #333; margin-top: 0;">
              <label class="form-check-label text-secondary" style="font-size: 0.9rem;" for="isGated">[ GATE_CONTENT ]</label>
            </div>
            
            <div class="d-flex align-items-center mb-2 me-4">
              <label for="bgColor" class="form-label text-secondary mb-0 me-2" style="font-size: 0.9rem;">BG_COLOR:</label>
              <input type="color" id="bgColor" name="bgColor" value="#0e0e0e" style="background-color: transparent; border: 1px solid #333; height: 30px; width: 40px; cursor: pointer;">
            </div>

            <div class="d-flex align-items-center mb-2 me-4">
              <label for="textColor" class="form-label text-secondary mb-0 me-2" style="font-size: 0.9rem;">TEXT_COLOR:</label>
              <input type="color" id="textColor" name="textColor" value="#f8f9fa" style="background-color: transparent; border: 1px solid #333; height: 30px; width: 40px; cursor: pointer;">
            </div>

            <div class="d-flex align-items-center mb-2 me-4">
              <label for="titleColor" class="form-label text-secondary mb-0 me-2" style="font-size: 0.9rem;">TITLE_COLOR:</label>
              <input type="color" id="titleColor" name="titleColor" value="#ffffff" style="background-color: transparent; border: 1px solid #333; height: 30px; width: 40px; cursor: pointer;">
            </div>

            <div class="d-flex align-items-center mb-2">
              <label for="borderColor" class="form-label text-secondary mb-0 me-2" style="font-size: 0.9rem;">BORDER_COLOR:</label>
              <input type="color" id="borderColor" name="borderColor" value="#333333" style="background-color: transparent; border: 1px solid #333; height: 30px; width: 40px; cursor: pointer;">
            </div>
          </div>
          <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary px-5 py-2">[ PUBLISH_RECORD ]</button>
            <a href="/" class="btn btn-outline-light px-4 py-2">[ CANCEL ]</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('./partials/footer'); -%>

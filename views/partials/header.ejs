<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Avirup Mondal Blog' %></title>
  <% if (typeof og !== 'undefined') { %>
    <meta property="og:title" content="<%= og.title %>" />
    <meta property="og:description" content="<%= og.description %>" />
    <meta property="og:type" content="article" />
  <% } %>
  <% if (typeof jsonLd !== 'undefined') { %>
    <script type="application/ld+json">
      <%- JSON.stringify(jsonLd) %>
    </script>
  <% } %>
  <link rel="manifest" href="/manifest.json">
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
  </script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Space Mono', monospace;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      background-color: #0e0e0e;
      color: #9ca3af;
      /* Subtle Grid Pattern */
      background-image: 
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    main {
      flex: 1;
    }
    .navbar {
      background-color: rgba(14, 14, 14, 0.95) !important;
      border-bottom: 1px solid #333 !important;
    }
    .navbar-brand {
      font-weight: 700;
      color: #e5e7eb !important;
      letter-spacing: 2px;
    }
    /* Terminal Block Overrides */
    .card {
      background: transparent !important;
      border: 1px solid #333 !important;
      border-radius: 0 !important;
      box-shadow: none !important;
    }
    .card:hover {
      border-color: #d1d5db !important;
    }
    .btn {
      border-radius: 0 !important;
      text-transform: uppercase;
      font-size: 0.8rem;
      letter-spacing: 1px;
    }
    .btn-primary {
      background-color: transparent !important;
      color: #e5e7eb !important;
      border: 1px solid #e5e7eb !important;
    }
    .btn-primary:hover {
      background-color: #e5e7eb !important;
      color: #0e0e0e !important;
    }
    .btn-outline-light {
      border-color: #4b5563 !important;
      color: #9ca3af !important;
    }
    .btn-outline-light:hover {
      background-color: #4b5563 !important;
      color: #fff !important;
    }
    .form-control {
      background-color: transparent !important;
      border: 1px solid #333 !important;
      border-radius: 0 !important;
      color: #e5e7eb !important;
    }
    .form-control:focus {
      border-color: #e5e7eb !important;
      box-shadow: none !important;
    }
    .error {
      color: #ef4444;
      margin: 10px 0;
      font-size: 0.8rem;
      font-weight: 600;
    }
    .terminal-header {
      font-weight: 700;
      color: #e5e7eb;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 1rem;
    }
    /* Simple ASCII Logo */
    .ascii-logo {
      font-size: 0.8rem;
      line-height: 1.2;
      white-space: pre;
      color: #4b5563;
      margin-bottom: 2rem;
    }
  </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/">> THE_MAINFRAME_</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav align-items-center">
        <!-- Audio Player (Hidden) -->
        <audio id="bgMusic" loop>
          <source src="https://cdn.pixabay.com/download/audio/2022/01/18/audio_d0a13f69d2.mp3?filename=cyberpunk-2099-10701.mp3" type="audio/mpeg">
        </audio>

        <% if (user) { %>
          <% if (user.isAdmin) { %>
            <li class="nav-item">
              <a class="nav-link btn btn-outline-danger btn-sm me-3 text-danger" href="/admin" style="border-color: #ef4444;">[ ADMIN_PANEL ]</a>
            </li>
          <% } %>
          <li class="nav-item me-3">
            <a class="nav-link text-secondary" href="/profile">usr: <%= user.username %></a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-light btn-sm me-2" href="/create">[ CREATE_POST ]</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-danger btn-sm text-danger me-4" href="/logout">[ LOGOUT ]</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">LOG_IN</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-primary btn-sm ms-2 me-4" href="/signup">[ SIGN_UP ]</a>
          </li>
        <% } %>

        <!-- Audio Controls -->
        <li class="nav-item me-2 d-flex align-items-center">
          <button id="musicToggle" class="nav-link btn btn-outline-light btn-sm" style="border: 1px solid #333 !important; font-size: 0.7rem;">[ 🔈 UNMUTE ]</button>
        </li>
        <!-- Discord Logo Button -->
        <li class="nav-item d-flex align-items-center">
          <a href="https://discord.gg/GJNdDzArvC" target="_blank" class="nav-link" title="Join Discord">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#5865F2" viewBox="0 0 16 16" style="margin-top: -2px;">
              <path d="M13.545 2.907a13.227 13.227 0 0 0-3.257-1.011.05.05 0 0 0-.052.025c-.141.25-.297.577-.406.833a12.19 12.19 0 0 0-3.658 0 8.258 8.258 0 0 0-.412-.833.051.051 0 0 0-.052-.025c-1.125.194-2.22.534-3.257 1.011a.041.041 0 0 0-.021.018C.356 6.024-.213 9.047.066 12.032c.001.014.01.028.021.037a13.276 13.276 0 0 0 3.995 2.02.05.05 0 0 0 .056-.019c.308-.42.582-.863.818-1.329a.05.05 0 0 0-.01-.059.051.051 0 0 0-.018-.011 8.875 8.875 0 0 1-1.248-.595.05.05 0 0 1-.02-.066.051.051 0 0 1 .015-.019c.084-.063.168-.129.248-.195a.05.05 0 0 1 .051-.007c2.619 1.196 5.454 1.196 8.041 0a.052.052 0 0 1 .053.007c.08.066.164.132.248.195a.051.051 0 0 1-.004.085 8.254 8.254 0 0 1-1.249.594.05.05 0 0 0-.03.03.052.052 0 0 0 .003.041c.24.465.515.909.817 1.329a.05.05 0 0 0 .056.019 13.235 13.235 0 0 0 4.001-2.02.049.049 0 0 0 .021-.037c.334-3.451-.559-6.449-2.366-9.106a.034.034 0 0 0-.02-.019Zm-8.198 7.307c-.789 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.45.73 1.438 1.613 0 .888-.637 1.612-1.438 1.612Zm5.316 0c-.788 0-1.438-.724-1.438-1.612 0-.889.637-1.613 1.438-1.613.807 0 1.451.73 1.438 1.613 0 .888-.631 1.612-1.438 1.612Z"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<main class="container py-5">
